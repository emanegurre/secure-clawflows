{
  "name": "secure-clawflows",
  "private": true,
  "version": "0.1.0",
  "description": "Security-first workflow runtime for OpenClaw.",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "git clean -xfd dist coverage .turbo",
    "cli": "node packages/cli/dist/bin.js",
    "install:openclaw": "node scripts/install-openclaw.mjs",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.8"
  }
}
